.resource-display {
    flex-direction: row;
    align-items: center;
    gap: var(--spacing-sm, 8px);
}

.resource-display__label {
    font-size: var(--font-body, 16px);
    color: var(--color-text, rgb(255, 255, 255));
    min-width: 80px;
}

.resource-display__value {
    font-size: var(--font-numbers, 18px);
    font-weight: bold;
    color: var(--color-accent, rgb(255, 215, 0));
}
